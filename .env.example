NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Cérebro da conversa: Anthropic (Claude). A chave pode ficar no banco
# (app_secrets.anthropic_api_key) ou aqui. Modelo padrão: claude-sonnet-5.
ANTHROPIC_API_KEY=
CONVERSATION_MODEL=claude-sonnet-5
# OpenAI segue necessária só para transcrever os áudios que o lead envia
# (Whisper) e para tarefas internas — a Anthropic não faz áudio.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

META_VERIFY_TOKEN=nexus-crm-verify-token
META_APP_ID=
META_APP_SECRET=
META_BUSINESS_ID=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v25.0
CLOSER_WHATSAPP_NUMBER=
